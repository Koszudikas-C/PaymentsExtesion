APP_ENV=development
NAME_APP=PaymentsExtension
CURL_SSL_NO_VERIFY=false

# Campaign settings
CAMPAIGN_TARGET=100

# Landing Page Sync (Webhooks)
LANDING_PAGE_WEBHOOK_URL=https://exemplo.com/webhook

# Discord Bot Sync
DISCORD_BOT_TOKEN=seu_discord_bot_token_aqui
DISCORD_LOG_CHANNEL_ID=123456789012345678

# Asaas
BASE_URL_ASAAS=sandbox.asaas.com
ASAAS_TOKEN=seu_asaas_token_aqui
ASAAS_ACCESS_TOKEN=seu_asaas_access_token_aqui

# Mail
MAIL_SMTP_HOST=smtp.exemplo.com
MAIL_USER=usuario@exemplo.com
MAIL_PASS=sua_senha_smtp_aqui
MAIL_SMTP_PORT=587
MAIL_SECURE=false
MAIL_FROM=no-reply@exemplo.com
MAIL_FROM_NAME='Nome do Remetente'

#License
LICENSE_SALT=um_valor_salt_aleatorio_aqui

#Db
DB_DRIVER=pdo_mysql
DB_HOST=127.0.0.1
DB_NAME=nome_do_banco
DB_USER=usuario_banco
DB_PASS=senha_banco
DB_STRESS_TIMEOUT_MS=2000

#Payment asaas
ASAAS_PAYMENT_LINK_ID=link_id_exemplo
ASAAS_PAYMENT_LINK=https://www.asaas.com/c/
MONTHLY_VALUE=29.99
MONTHLY_NAME='AIFreelas - Assinatura Mensal'

# Performance Profiling (threshold em ms para alertas de lentidão no Discord)
PERFORMANCE_THRESHOLD_MS=1000

# Timezone da aplicação (Padrão: America/Sao_Paulo)
APP_TIMEZONE=America/Sao_Paulo
# CORS Configuration
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,chrome-extension://id_da_extensao"

# Stripe Configuration (Internacional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PAYMENT_LINK_ID="test_link_id"
